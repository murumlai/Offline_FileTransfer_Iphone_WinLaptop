<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <!-- Drop machine/user-level private feeds so restore does not fail on unauthorized sources. -->
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
  </packageSources>
</configuration>
